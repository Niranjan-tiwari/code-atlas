{
  "services": [
    {
      "service_name": "dbus-fi.w1.wpa_supplicant1",
      "file_path": "/etc/systemd/system/dbus-fi.w1.wpa_supplicant1.service",
      "working_directory": null,
      "exec_start": "/sbin/wpa_supplicant -u -s -O /run/wpa_supplicant"
    },
    {
      "service_name": "dbus-org.freedesktop.Avahi",
      "file_path": "/etc/systemd/system/dbus-org.freedesktop.Avahi.service",
      "working_directory": null,
      "exec_start": "/usr/sbin/avahi-daemon -s"
    },
    {
      "service_name": "dbus-org.freedesktop.timesync1",
      "file_path": "/etc/systemd/system/dbus-org.freedesktop.timesync1.service",
      "working_directory": null,
      "exec_start": "!!/lib/systemd/systemd-timesyncd"
    },
    {
      "service_name": "dbus-org.freedesktop.thermald",
      "file_path": "/etc/systemd/system/dbus-org.freedesktop.thermald.service",
      "working_directory": null,
      "exec_start": "/usr/sbin/thermald --systemd --dbus-enable --adaptive"
    },
    {
      "service_name": "redis",
      "file_path": "/etc/systemd/system/redis.service",
      "working_directory": null,
      "exec_start": "/usr/bin/redis-server /etc/redis/redis.conf --supervised systemd --daemonize no"
    },
    {
      "service_name": "dbus-org.freedesktop.oom1",
      "file_path": "/etc/systemd/system/dbus-org.freedesktop.oom1.service",
      "working_directory": null,
      "exec_start": "/lib/systemd/systemd-oomd"
    },
    {
      "service_name": "dbus-org.freedesktop.nm-dispatcher",
      "file_path": "/etc/systemd/system/dbus-org.freedesktop.nm-dispatcher.service",
      "working_directory": null,
      "exec_start": "/usr/lib/NetworkManager/nm-dispatcher"
    },
    {
      "service_name": "dbus-org.freedesktop.ModemManager1",
      "file_path": "/etc/systemd/system/dbus-org.freedesktop.ModemManager1.service",
      "working_directory": null,
      "exec_start": "/usr/sbin/ModemManager"
    },
    {
      "service_name": "syslog",
      "file_path": "/etc/systemd/system/syslog.service",
      "working_directory": null,
      "exec_start": "/usr/sbin/rsyslogd -n -iNONE"
    },
    {
      "service_name": "sshd",
      "file_path": "/etc/systemd/system/sshd.service",
      "working_directory": null,
      "exec_start": "/usr/sbin/sshd -D $SSHD_OPTS"
    },
    {
      "service_name": "sudo",
      "file_path": "/etc/systemd/system/sudo.service",
      "working_directory": null,
      "exec_start": null
    },
    {
      "service_name": "dbus-org.bluez",
      "file_path": "/etc/systemd/system/dbus-org.bluez.service",
      "working_directory": null,
      "exec_start": "/usr/lib/bluetooth/bluetoothd"
    },
    {
      "service_name": "SRStreamer",
      "file_path": "/etc/systemd/system/SRStreamer.service",
      "working_directory": null,
      "exec_start": "/opt/splashtop-streamer/SRFeature"
    },
    {
      "service_name": "anydesk",
      "file_path": "/etc/systemd/system/anydesk.service",
      "working_directory": null,
      "exec_start": "/usr/bin/anydesk --service"
    },
    {
      "service_name": "dbus-org.freedesktop.resolve1",
      "file_path": "/etc/systemd/system/dbus-org.freedesktop.resolve1.service",
      "working_directory": null,
      "exec_start": "!!/lib/systemd/systemd-resolved"
    },
    {
      "service_name": "AteraAgent",
      "file_path": "/etc/systemd/system/AteraAgent.service",
      "working_directory": "/usr/lib/atera-agent",
      "exec_start": "/usr/lib/atera-agent/.dotnet/dotnet /usr/lib/atera-agent/bin/Atera.Agent.Linux.dll"
    },
    {
      "service_name": "display-manager",
      "file_path": "/etc/systemd/system/display-manager.service",
      "working_directory": null,
      "exec_start": "/usr/sbin/gdm3"
    },
    {
      "service_name": "versa-sase",
      "file_path": "/etc/systemd/system/versa-sase.service",
      "working_directory": null,
      "exec_start": "/usr/bin/VersaSASEServer"
    }
  ],
  "mapping": {
    "redis": "whatspp_redis_bridge"
  }
}