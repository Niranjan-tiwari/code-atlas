{
  "llm": {
    "default_model": "openai",
    "fallback_chain": ["openai", "claude", "gemini"],
    "strategy": {
      "code_generation": "openai",
      "code_review": "claude",
      "documentation": "claude",
      "simple": "gemini",
      "cost_optimization": true,
      "quality_threshold": 0.8
    },
    "openai": {
      "enabled": true,
      "api_key": "${OPENAI_API_KEY}",
      "model": "gpt-4",
      "models": {
        "gpt-4": {
          "max_tokens": 8000,
          "temperature": 0.7
        },
        "gpt-3.5-turbo": {
          "max_tokens": 4000,
          "temperature": 0.7
        }
      }
    },
    "claude": {
      "enabled": true,
      "api_key": "${ANTHROPIC_API_KEY}",
      "model": "claude-sonnet-4",
      "models": {
        "claude-sonnet-4": {
          "max_tokens": 8000,
          "temperature": 0.7
        },
        "claude-opus": {
          "max_tokens": 4000,
          "temperature": 0.5
        },
        "claude-haiku": {
          "max_tokens": 4000,
          "temperature": 0.7
        }
      }
    },
    "gemini": {
      "enabled": true,
      "api_key": "${GEMINI_API_KEY}",
      "model": "gemini-pro",
      "models": {
        "gemini-pro": {
          "max_tokens": 8000,
          "temperature": 0.7
        },
        "gemini-ultra": {
          "max_tokens": 8000,
          "temperature": 0.5
        }
      }
    }
  },
  "vector_db": {
    "provider": "chromadb",
    "persist_directory": "./data/vector_db",
    "collection_name": "code_snippets"
  },
  "rag": {
    "chunk_size": 1000,
    "chunk_overlap": 200,
    "top_k": 5,
    "similarity_threshold": 0.7
  },
  "observability": {
    "langsmith": {
      "enabled": true,
      "api_key": "${LANGCHAIN_API_KEY}",
      "project": "code-atlas"
    }
  }
}
