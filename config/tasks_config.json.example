      "description": "Add Prometheus metrics",
      "branch_name": "feature/add-metrics",
      "continue_on_existing": false,
      "files_to_modify": [
        "internal/jobs/worker.go"
      ],
      "changes": {
        "worker.go": "Add Prometheus metrics instrumentation"
      },
      "code_changes": {
        "internal/jobs/worker.go": "// Add metrics\nimport \"github.com/prometheus/client_golang/prometheus\"\n\nvar (\n    messagesProcessed = prometheus.NewCounterVec(\n        prometheus.CounterOpts{\n            Name: \"messages_processed_total\",\n            Help: \"Total number of messages processed\",\n        },\n        []string{\"status\"},\n    )\n)\n\nfunc init() {\n    prometheus.MustRegister(messagesProcessed)\n}"
      },
      "commit_message": "feat: add Prometheus metrics"
