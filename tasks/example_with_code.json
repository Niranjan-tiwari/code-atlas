      "code_changes": {
        "VERSION": "2.1.0\n"
      },
      "commit_message": "[PROJ-5678] feat: add version file"
    },
    {
      "repo": "service-gamma",
      "description": "Add version file with build info",
      "files_to_modify": ["VERSION", "build_info.go"],
      "code_changes": {
        "VERSION": "1.5.0\n",
        "build_info.go": "package main\n\nconst Version = \"1.5.0\"\n"
