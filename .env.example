# Copy to .env and fill in locally. Never commit .env (see .gitignore).
# scripts/query_code.py loads .env automatically (python-dotenv; pip install -r requirements.txt).
# Other entrypoints may still need: export $(grep -v '^#' .env | xargs) or your shell profile.
# Config JSON may reference ${VAR} placeholders where documented.

# --- LLM providers (set at least one if you use /api/query, explain, review) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=

# --- Git automation (optional; parallel task runner / GitLab API) ---
# GITLAB_TOKEN=

# --- Notifications (optional) ---
# SLACK_WEBHOOK_URL=
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# CALLMEBOT_API_KEY=
# WHATSAPP_WEBHOOK_URL=

# --- Embeddings & vector index ---
# EMBED_MODEL=bge-small
# QDRANT_PATH=./data/qdrant_db

# --- Bulk indexing ---
# CODE_ATLAS_INDEX_PATHS=/path/ws1:/path/ws2
# INDEX_REPO_TIMEOUT_SEC=3600
# INDEX_BULK_IN_PROCESS=1   # faster: one process, model loaded once (no per-repo subprocess timeout)
# INDEX_HEALTH_STALE_MINUTES=20
# REPOS_BASE_PATH=

# --- Reranker ---
# RERANKER=flashrank
# FLASHRANK_MODEL=ms-marco-TinyBERT-L-2-v2

# --- Observability (optional) ---
# LANGCHAIN_API_KEY=

# --- CI / tests: skip remote LLM calls ---
# SKIP_LLM=1
